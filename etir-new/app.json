{
  "expo": {
    "name": "Etir",
    "slug": "etir",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "etir",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "remote-notification",
          "location",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSCalendarsUsageDescription": "Etir uses calendar access to schedule shipment pickup and delivery reminders.",
        "NSContactsUsageDescription": "Etir uses contacts access to help you quickly add client and driver contact information.",
        "NSCameraUsageDescription": "Etir uses the camera to scan and upload shipment documents and delivery proof photos."
      },
      "backgroundModes": [
        "location",
        "location"
      ],
      "bundleIdentifier": "com.maras.etir"
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#0D1117",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "e-tir Gateway",
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      "expo-task-manager",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow e-tir Gateway to use your location for live GPS shipment tracking, including when the app is in the background.",
          "locationWhenInUsePermission": "Allow e-tir Gateway to access your location to share your position with dispatch.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "515ca00f-72f2-4430-af59-43c33733dd34"
      }
    },
    "owner": "sardar89"
  }
}