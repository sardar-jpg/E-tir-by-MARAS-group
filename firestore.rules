rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // SECURITY MODEL: deny ALL direct client access to Firestore.
    //
    // Every legitimate read/write goes through the Express backend (server.ts)
    // and the operational scripts (scripts/*.ts), all of which use the Firebase
    // Admin SDK authenticating via Application Default Credentials. The Admin SDK
    // is a trusted-server identity and BYPASSES these rules entirely, so this
    // deny-all rule does not affect the app's own access — it only guarantees
    // that no end-user, anonymous, or other signed-in client can read or write
    // this database directly, even if they know a collection or document path.
    //
    // Verified in audit/firebase-full-environment-hardening (PR #121): the repo
    // contains ZERO firebase/firestore client-SDK usage. The web/mobile apps use
    // firebase/auth only for identity and reach all data via the Express API.
    // This replaces the previous single-hardcoded-UID rule, which is no longer
    // load-bearing now that the server uses the Admin SDK.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
