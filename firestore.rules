rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // SECURITY MODEL: only the server's own dedicated Firebase Auth account
    // (created once, in Firebase Console > Authentication, never exposed to
    // end users) may read or write anything. No other signed-in user, and
    // no anonymous/unauthenticated request, can touch this database.
    //
    // Real authorization for *humans* (which admin can do what, which
    // driver can see which shipment, etc.) is enforced in the Express
    // server itself (see server.ts requireAuth/requireRole middleware) —
    // this rule's only job is to make sure NOTHING can reach Firestore
    // except through that server.
    //
    // Previously every collection here had `allow read: if true`, which
    // meant anyone on the internet could read the entire database
    // (including plaintext passwords) with no login at all. That hole is
    // closed below.
    function isServerAccount() {
      return request.auth != null && request.auth.uid == "mQadHKcpmgbLIAwQaz8AqrAytIo2";
    }

    match /{document=**} {
      allow read, write: if isServerAccount();
    }
  }
}
