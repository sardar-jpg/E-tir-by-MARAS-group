# ── Security (added by the security audit fix — REQUIRED, server will not start without these) ──

# SESSION_SECRET: signs every login session token. Generate a real random
# value with `openssl rand -base64 48` — never reuse this example value.
SESSION_SECRET=""

# Firebase server-side auth: this server uses the Firebase Admin SDK with
# Application Default Credentials (ADC) for Firestore/Storage — NOT a
# username/password, and NOT a JSON key file in this repo. Nothing to set
# here for that. Instead:
#   - Local development: run `gcloud auth application-default login` once
#     (interactive, stores credentials outside this repo — nothing to add
#     to this file).
#   - Cloud Run (production): ADC resolves automatically via the service's
#     own attached runtime service account. No env var or secret needed —
#     just make sure that service account has the Cloud Datastore User and
#     Storage Object Admin IAM roles.
# See docs/REAL_FIREBASE_VERIFICATION.md for the full explanation.

# GOOGLE_APPLICATION_CREDENTIALS: optional, NOT required for the ADC setup
# above. Only set this if you specifically want to use a downloaded
# service-account JSON key instead of `gcloud auth application-default
# login` — point it at an absolute path OUTSIDE this repo; never place a
# service-account key file inside the repo itself.
GOOGLE_APPLICATION_CREDENTIALS=""

# SERVER_FIREBASE_UID: NOT a secret — a verification value only, checked by
# `npm run check-firebase-readiness` (scripts/check-firebase-readiness.ts).
# Historical/legacy: firestore.rules and storage.rules still hardcode a
# specific Firebase Auth UID from before this server used the Admin SDK.
# The Admin SDK bypasses those rules entirely (see server.ts), so this UID
# no longer governs the server's own access — it's kept here only until
# those rule files are updated in a follow-up change. Leave unset if you
# haven't looked this up. Never put a password or session token here.
SERVER_FIREBASE_UID=""

# STRICT_PERSISTENCE: on by default (anything other than the literal string
# "false" counts as on). When on, a write to a collection fails loudly
# (503 Service Unavailable) instead of silently landing in the volatile
# in-memory fallback store if Firestore is unreachable. Keep this at its
# default in production — only set to "false" for local dev if you
# specifically want writes to succeed against memory when Firestore isn't
# configured.
STRICT_PERSISTENCE=""

# SEED_DEMO_DATA: off by default. When "true", the server seeds demo
# accounts/records (with known, source-visible passwords) into whichever
# store is active (Firestore or memory). Never set this to "true" in
# production — see src/lib/persistenceReadiness.ts, which warns loudly at
# startup if it detects this combination.
SEED_DEMO_DATA=""

# SUPER_ADMIN_EMAIL: the email/username the root admin logs in with.
SUPER_ADMIN_EMAIL="sardar@maras.iq"

# SUPER_ADMIN_PASSWORD_HASH: generate with `npm run hash-password` (prompts
# for a password, prints the hash to paste here). Never put the plaintext
# password itself in this file or anywhere in the codebase.
SUPER_ADMIN_PASSWORD_HASH=""

# GEMINI_API_KEY: leftover from this app's original AI Studio prototype
# scaffold. Not read by any currently shipped feature (the MARAS AI Monitor
# header drawer is UI-only, with no backend/provider wired up yet — see
# docs/FOLLOW_UP_ROADMAP.md). Safe to leave unset until that ships.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: this app deploys to Cloud Run via a Cloud Build trigger on every
# push to `main` (see ETIR-PROJECT-REFERENCE.md) — nothing auto-injects this
# at runtime. Set it explicitly if this deployment's own self-referential
# links/API base URL differ from https://etir.app.
# Also added to the CORS allowlist (see src/lib/cors.ts) — the server only
# grants credentialed cross-origin access to this origin, the local dev
# origins, https://etir.app/www.etir.app, and whatever else is listed in
# CLIENT_URL / ALLOWED_ORIGINS / PUBLIC_APP_URL below.
APP_URL="MY_APP_URL"

# CLIENT_URL / ALLOWED_ORIGINS / PUBLIC_APP_URL: additional origins for the
# CORS allowlist above, on top of APP_URL. ALLOWED_ORIGINS may be a
# comma-separated list if more than one extra origin is needed (e.g. a
# staging frontend). All are optional.
CLIENT_URL=""
ALLOWED_ORIGINS=""
PUBLIC_APP_URL=""

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps API integration.
# Users obtain this key from the Google Cloud Console and save it in Settings -> Secrets.
# This key is served to the frontend (it's meant to be — Maps JS API keys are
# not secret by design) via GET /api/maps-key, which is fine as long as the
# key itself is restricted in Google Cloud Console > Credentials > this key >
# "Application restrictions" > HTTP referrers, to this app's real domain(s).
# An unrestricted key lets anyone who reads it from the page source bill
# usage to this project from any site. Verify/set that restriction before
# going live with a production key — this PR does not change Google Cloud
# config, so it isn't done here.
GOOGLE_MAPS_PLATFORM_KEY=

# DD_API_KEY: Datadog API Key for tracing and active performance logging.
# Generate yours in Datadog -> Organization Settings -> API Keys
DD_API_KEY=

# DD_ENV: Environment name for Datadog tracing metrics (e.g. production, staging, development)
DD_ENV="production"


# ── MARAS AI (PR #128) — Admin Panel internal assistant ──
# MARAS AI runs ONLY when BOTH values below are set. Leave them empty to
# keep the feature cleanly disabled (the Admin Panel keeps working and the
# drawer shows a clear "unavailable" message).
#
# OPENAI_API_KEY: server-side ONLY — it is never sent to any browser and
# must NEVER be committed to this repository. Create one in the OpenAI
# dashboard and set it in the server's environment (Cloud Run env var /
# local .env, both outside version control).
OPENAI_API_KEY=""
# OPENAI_MODEL: optional model override; defaults to the model in
# src/lib/marasAiCore.ts (DEFAULT_OPENAI_MODEL) when empty.
OPENAI_MODEL=""
# MARAS_AI_ENABLED: master switch — must literally be "true" to enable.
MARAS_AI_ENABLED=""
