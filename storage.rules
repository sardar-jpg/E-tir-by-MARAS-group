rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // SECURITY MODEL: deny ALL direct client access to Storage.
    //
    // Every upload and every file read goes through the Express backend
    // (server.ts /api/upload and the file-serving routes), which uses the
    // Firebase Admin SDK authenticating via Application Default Credentials. The
    // Admin SDK is a trusted-server identity and BYPASSES these rules entirely,
    // so this deny-all rule does not affect the app's own access — it only
    // guarantees that no file is readable or writable directly, even by someone
    // who knows its Firebase Storage URL.
    //
    // Verified in audit/firebase-full-environment-hardening (PR #121): the repo
    // contains ZERO firebase/storage client-SDK usage. This replaces the previous
    // single-hardcoded-UID rule, which is no longer load-bearing now that the
    // server uses the Admin SDK.

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
