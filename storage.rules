rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Same security model as firestore.rules: only the server's own
    // dedicated Firebase Auth account may read or write anything in
    // Storage. End users never talk to Storage directly — every upload
    // and every file URL goes through the Express server (see
    // /api/upload and /api/uploads/:id in server.ts), which serves files
    // back over HTTP after checking the requester's own session/role.
    //
    // Without this file, a fresh Firebase project defaults to denying all
    // Storage access, which would make every upload silently fail. This
    // rule grants access to exactly one specific account (matching
    // firestore.rules) rather than leaving Storage's defaults unconfigured
    // or, worse, wide open.
    function isServerAccount() {
      return request.auth != null && request.auth.uid == "DpfqNKAi9dUOW6ksGlDVXWcCvVJ2";
    }

    match /{allPaths=**} {
      allow read, write: if isServerAccount();
    }
  }
}
